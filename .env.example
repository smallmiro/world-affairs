# Database
DATABASE_URL="file:../db/data.sqlite"

# AI (Gemini API - translation, summarization, analysis, briefing)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# Aviation - Airport Monitor
AVIATIONSTACK_API_KEY=your_aviationstack_api_key_here
OPENSKY_USERNAME=your_opensky_client_id_here
OPENSKY_PASSWORD=your_opensky_client_secret_here

# Vessel Tracking (AISStream.io WebSocket)
AISSTREAM_API_KEY=your_aisstream_api_key_here

# Internal SSE Communication (Optional)
SSE_PUBLISH_URL=http://localhost:3000/api/sse/publish
INTERNAL_API_KEY=world-affairs-internal
